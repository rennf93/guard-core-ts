{
  "name": "@guardcore/hono",
  "version": "1.0.0",
  "description": "Hono adapter for @guardcore/core security middleware (edge-safe)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@guardcore/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8",
    "vitest": "^4",
    "typescript": "~5.9",
    "hono": "^4"
  },
  "peerDependencies": {
    "hono": "^4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rennf93/guard-core-ts.git",
    "directory": "packages/hono"
  },
  "publishConfig": {
    "access": "public"
  }
}
